# Fastfile fuer Handwerker Dashboard iOS App
# Automatisiertes Build & Deployment zum App Store

default_platform(:ios)

platform :ios do

  desc "Zertifikate und Provisioning Profiles synchronisieren"
  lane :certificates do
    match(
      type: "appstore",
      app_identifier: "com.meisterbauer.dashboard",
      readonly: true
    )
  end

  desc "Build-Nummer automatisch erhoehen"
  lane :bump do
    increment_build_number(
      xcodeproj: "App.xcodeproj"
    )
  end

  desc "App fuer den App Store bauen"
  lane :build do
    certificates

    build_app(
      workspace: nil,
      project: "App.xcodeproj",
      scheme: "App",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "HandwerkerDashboard.ipa",
      clean: true,
      xcargs: "-allowProvisioningUpdates"
    )
  end

  desc "Screenshots fuer den App Store erstellen"
  lane :screenshots do
    capture_screenshots
  end

  desc "App zum App Store Connect hochladen (TestFlight)"
  lane :beta do
    bump
    build

    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )

    UI.success("App erfolgreich zu TestFlight hochgeladen!")
  end

  desc "App im App Store veroeffentlichen"
  lane :release do
    bump
    build

    upload_to_app_store(
      submit_for_review: true,
      automatic_release: false,
      force: false,
      skip_metadata: false,
      skip_screenshots: true,
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa: false
      }
    )

    UI.success("App erfolgreich zum App Store eingereicht!")
  end

  desc "Nur Metadaten und Screenshots hochladen"
  lane :metadata do
    upload_to_app_store(
      skip_binary_upload: true,
      skip_screenshots: false,
      force: true
    )
  end

  # Fehlerbehandlung
  error do |lane, exception|
    UI.error("Fehler in Lane '#{lane}': #{exception.message}")
  end

end
